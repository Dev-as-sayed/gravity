// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================================================
// ENUMS
// ==================================================

enum UserRole {
  TEACHER
  MODERATOR
  STUDENT
  GUARDIAN
  ADMIN
  SUPER_ADMIN
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
  CANCELLED
  COMPLETED
  DROPPED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  COMPLETED
  OVERDUE
  REFUNDED
  FAILED
  PROCESSING
}

enum PaymentMethod {
  ONLINE
  MANUAL
  INSTALLMENT
  SCHOLARSHIP
  CARD
  UPI
  NET_BANKING
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ExamStatus {
  DRAFT
  SCHEDULED
  ONGOING
  COMPLETED
  RESULT_PUBLISHED
  ARCHIVED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
  HOLIDAY
}

enum NotificationType {
  CLASS_REMINDER
  EXAM_UPDATE
  PAYMENT_REMINDER
  RESULT_ANNOUNCEMENT
  ATTENDANCE_ALERT
  GENERAL_ANNOUNCEMENT
  DUE_ALERT
  BATCH_UPDATE
  ASSIGNMENT_POSTED
  DOUBT_RESOLVED
  COMMENT_REPLY
  REACTION_RECEIVED
}

enum NotificationChannel {
  INAPP
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

enum BatchMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  REPORTED
  HIDDEN
  DELETED
}

enum PostVisibility {
  PUBLIC
  STUDENTS_ONLY
  BATCH_ONLY
  TEACHERS_ONLY
  MODERATORS_ONLY
  PRIVATE
}

enum ReactionType {
  LIKE
  LOVE
  HAHA
  WOW
  SAD
  ANGRY
  HELPFUL
  INSIGHTFUL
  CELEBRATE
  SUPPORT
}

enum MediaType {
  IMAGE
  VIDEO
  PDF
  LINK
  TEXT
  MIXED
  AUDIO
  DOCUMENT
}

enum CommentStatus {
  ACTIVE
  HIDDEN
  REPORTED
  DELETED
  FLAGGED
}

enum DoubtStatus {
  OPEN
  ANSWERED
  RESOLVED
  CLOSED
  ESCALATED
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  ACTIVE
  CLOSED
  GRADED
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  GRADED
  LATE
  RESUBMITTED
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum CertificateType {
  COURSE_COMPLETION
  ACHIEVEMENT
  PARTICIPATION
  EXCELLENCE
}

enum ResourceType {
  NOTE
  VIDEO
  ASSIGNMENT
  PRACTICE_SET
  REFERENCE
  FORMULA_SHEET
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  ESCALATED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ==================================================
// CORE USER MODELS
// ==================================================

// User Model (Base for all roles)
model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password       String // Hashed password
  phone          String    @unique
  alternatePhone String?
  role           UserRole  @default(STUDENT)
  isActive       Boolean   @default(true)
  isVerified     Boolean   @default(false)
  emailVerified  Boolean   @default(false)
  phoneVerified  Boolean   @default(false)
  lastLogin      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Profile
  name               String?
  profileImage       String?
  coverImage         String?
  bio                String?
  dateOfBirth        DateTime?
  gender             Gender?
  address            String?
  city               String?
  state              String?
  country            String?
  pincode            String?
  timezone           String?  @default("Asia/Kolkata")
  language           String?  @default("en")

  // Security
  twoFactorEnabled   Boolean   @default(false)
  twoFactorSecret    String?
  resetPasswordToken String?
  resetPasswordExp   DateTime?
  verificationToken  String?
  verificationExp    DateTime?
  loginAttempts      Int       @default(0)
  lockedUntil        DateTime?
  refreshToken       String?

  // Relations based on role
  teacher            Teacher?
  moderator          Moderator?
  student            Student?
  guardian           Guardian?
  admin              Admin?

  // Notifications
  notifications           Notification[]
  notificationPreferences NotificationPreference[]

  // Sessions
  sessions Session[]

  // Audit logs
  auditLogs     AuditLog[]
  otps          OTP[]
  deviceTokens  DeviceToken[]
  userActivity  UserActivity[]
  supportTickets SupportTicket[]      @relation("UserTickets")
  assignedTickets SupportTicket[]     @relation("AssignedTickets")

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([createdAt])
}

// Teacher Profile
model Teacher {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal Info
  name          String
  bio           String?
  qualification String?
  expertise     String[] // Subjects they teach
  profileImage  String?
  coverImage    String?
  designation   String?
  institute     String?
  experience    Int? // Years of experience
  achievements  String[]

  // Professional
  employeeId      String? @unique
  joiningDate     DateTime?
  specializations String[]
  researchPapers  Json?   // List of publications
  awards          String[]

  // Business
  gstNumber   String?
  panNumber   String?
  bankDetails Json? // Store encrypted bank details
 upiId       String?

  // Settings
  settings Json? // Teacher preferences
  officeHours Json? // Available hours for consultation

  // Social Links
  website     String?
  linkedin    String?
  youtube     String?
  twitter     String?

  // Stats
  totalStudents    Int @default(0)
  averageRating    Float @default(0)
  totalCourses     Int @default(0)
  totalBatches     Int @default(0)
  totalReviews     Int @default(0)

  // Relations
  batches          Batch[]           @relation("TeacherBatches")
  courses          Course[]          @relation("TeacherCourses")
  exams            Exam[]            @relation("TeacherExams")
  quizzes          Quiz[]            @relation("TeacherQuizzes")
  notes            Note[]            @relation("TeacherNotes")
  blogs            Blog[]            @relation("TeacherBlogs")
  posts            Post[]            @relation("TeacherPosts")
  doubts           Doubt[]           @relation("TeacherDoubts")
  assignments      Assignment[]      @relation("TeacherAssignments")
  reviews          TeacherReview[]
  certificates     Certificate[]     @relation("TeacherCertificates")
  liveSessions     LiveSession[]     @relation("TeacherSessions")
  announcements    Announcement[]    @relation("TeacherAnnouncements")

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  teacherSubscriptions TeacherSubscription[]
}

// Moderator Profile
model Moderator {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  assignedBy  String // Teacher/Admin ID who assigned them
  permissions Json // Granular permissions

  // Assigned batches
  batches Batch[] @relation("ModeratorBatches")

  // Activity
  lastActive     DateTime?
  actionsTaken   Int @default(0)
  resolvedIssues Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Admin Profile
model Admin {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  role          String // SUPER_ADMIN, CONTENT_ADMIN, FINANCE_ADMIN, SUPPORT_ADMIN
  permissions   Json
  department    String?
  lastActive    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Student Profile
model Student {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal Info
  name          String
  dateOfBirth   DateTime?
  gender        Gender?
  address       String?
  city          String?
  state         String?
  country       String?
  pincode       String?
  profileImage  String?
  coverImage    String?

  // Academic
  institute          String?
  educationLevel     String? // High School, College, etc.
  class              String? // 11, 12, etc.
  board              String? // CBSE, ICSE, State Board
  hscYear            Int? // Year of HSC exam
  group              String? // Science, Commerce, Arts
  rollNumber         String?
  registrationNumber String?

  // Guardian
  guardianId String?
  guardian   Guardian? @relation("StudentGuardian", fields: [guardianId], references: [id])

  // Preferences
  preferredSubjects String[]
  learningGoals     String[]
  examTargets       String[] // ["JEE", "NEET", etc.]

  // Stats
  totalCourses     Int @default(0)
  averageScore     Float @default(0)
  attendanceRate   Float @default(0)
  rank             Int?
  percentile       Float?

  // Relations
  enrollments      Enrollment[]
  attendances      Attendance[]
  quizResults      QuizResult[]
  examResults      ExamResult[]
  payments         Payment[]
  notes            Note[] // Downloaded notes
  wishlist         Batch[]           @relation("StudentWishlist")
  posts            Post[]            @relation("StudentPosts")
  comments         Comment[]         @relation("StudentComments")
  reactions        PostReaction[]    @relation("StudentReactions")
  bookmarks        PostBookmark[]
  doubts           Doubt[]           @relation("StudentDoubts")
  submissions      AssignmentSubmission[]
  certificates     Certificate[]     @relation("StudentCertificates")
  reviews          TeacherReview[]
  liveSessions     LiveSession[]     @relation("StudentSessions")
  pollVotes        PollVote[]

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  quizAttempts      QuizAttempt[]
  studentProgresses StudentProgress[]
}

// Guardian Profile
model Guardian {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String
  relationship String // Father, Mother, Guardian
  occupation   String?
  income       Float?

  // Relations
  students Student[] @relation("StudentGuardian")

  // Preferences
  notificationPrefs Json? // How they want to be notified about student progress

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================================================
// BATCH MANAGEMENT
// ==================================================

// Course (Parent of Batches)
model Course {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String?
  subject     String
  category    String // Science, Commerce, Arts
  thumbnail   String?
  bannerImage String?
  icon        String?

  teacherId String
  teacher   Teacher @relation("TeacherCourses", fields: [teacherId], references: [id])

  // Course details
  duration     Int? // in hours
  level        DifficultyLevel @default(BEGINNER)
  prerequisites String[]
  learningOutcomes String[]

  // Pricing
  price        Float
  offerPrice   Float?
  isFree       Boolean @default(false)

  // Stats
  totalBatches     Int @default(0)
  totalStudents    Int @default(0)
  averageRating    Float @default(0)
  totalReviews     Int @default(0)

  // SEO
  metaTitle       String?
  metaDescription String?
  metaKeywords    String[]

  batches   Batch[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId])
  @@index([slug])
}

// Batch Model
model Batch {
  id   String @id @default(cuid())
  name String
  slug String @unique

  // Basic Info
  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  teacherId String
  teacher   Teacher @relation("TeacherBatches", fields: [teacherId], references: [id])

  moderators Moderator[] @relation("ModeratorBatches")

  // Batch Details
  subject     String
  description String?
  mode        BatchMode @default(ONLINE)
  language    String?   @default("English")

  // Capacity
  maxStudents        Int?
  currentEnrollments Int  @default(0)
  waitlistCount      Int  @default(0)
  minimumStudents    Int? // Minimum required to start

  // Schedule
  startDate    DateTime
  endDate      DateTime?
  schedule     Json? // Weekly schedule {monday: "10:00-12:00", ...}
  totalClasses Int?
  completedClasses Int @default(0)

  // Live Class
  liveClassLink     String?
  liveClassPlatform String? // Zoom, Google Meet, Teams
  meetingId         String?
  meetingPassword   String?
  recordingUrl      String? // Recorded sessions link

  // Study Material
  studyMaterialUrl String?
  resources        Json? // Additional resources

  // Pricing
  price         Float
  offerPrice    Float?
  offerDeadline DateTime?

  // Early Bird
  earlyBirdPrice    Float?
  earlyBirdDeadline DateTime?

  // Discounts
  discountPercent Float?
  discountCode    String?

  // Status
  isActive       Boolean @default(true)
  isPublished    Boolean @default(false)
  enrollmentOpen Boolean @default(true)
  visibility     String  @default("PUBLIC") // PUBLIC, PRIVATE, LINK_ONLY

  // Syllabus
  syllabus       Json?
  topics         String[]
  prerequisites  String[]

  // Ratings
  averageRating Float @default(0)
  totalReviews  Int   @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  enrollments      Enrollment[]
  notes            Note[]
  quizzes          Quiz[]
  exams            Exam[]
  attendances      Attendance[]
  announcements    Announcement[]
  assignments      Assignment[]
  liveSessions     LiveSession[]
  doubts           Doubt[]
  materials        BatchMaterial[]
  reviews          BatchReview[]

  // Wishlisted by students
  wishlistedBy      Student[]         @relation("StudentWishlist")
  studentProgresses StudentProgress[]

  @@index([teacherId])
  @@index([courseId])
  @@index([isActive])
  @@index([startDate])
}

// Batch Materials
model BatchMaterial {
  id        String @id @default(cuid())
  batchId   String
  batch     Batch  @relation(fields: [batchId], references: [id])

  title       String
  description String?
  type        ResourceType
  fileUrl     String?
  fileSize    Int?
  duration    Int? // For videos
  isFree      Boolean @default(false)

  uploadedBy  String // Teacher/Moderator ID
  uploadedAt  DateTime @default(now())

  downloads   Int @default(0)
  views       Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Enrollment
model Enrollment {
  id String @id @default(cuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  batchId String
  batch   Batch  @relation(fields: [batchId], references: [id])

  status EnrollmentStatus @default(PENDING)

  // Enrollment Details
  appliedAt      DateTime  @default(now())
  approvedAt     DateTime?
  rejectedAt     DateTime?
  rejectedReason String?
  completedAt    DateTime?
  droppedAt      DateTime?
  droppedReason  String?

  // Payment
  paymentStatus PaymentStatus @default(PENDING)
  totalFees     Float
  paidAmount    Float         @default(0)
  dueAmount     Float         @default(0)

  // Discount
  couponCode        String?
  discountAmount    Float   @default(0)
  scholarshipAmount Float   @default(0)
  scholarshipReason String?

  // Installments
  installmentPlan Json? // {total: 3, paid: 1, nextDue: date, amount: 5000}
  installments    Installment[]

  // Progress
  progressPercentage Float @default(0)
  classesAttended    Int   @default(0)
  totalClasses       Int   @default(0)
  assignmentsDone    Int   @default(0)
  averageScore       Float @default(0)

  // Metadata
  metadata Json?

  payments  Payment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([studentId, batchId])
  @@index([status])
  @@index([batchId])
}

// Installments
model Installment {
  id           String @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])

  amount      Float
  dueDate     DateTime
  paidDate    DateTime?
  status      PaymentStatus @default(PENDING)
  paymentId   String? // Link to payment once paid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Batch Reviews
model BatchReview {
  id        String @id @default(cuid())
  batchId   String
  batch     Batch  @relation(fields: [batchId], references: [id])
  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  rating     Int // 1-5
  comment    String?
  pros       String[]
  cons       String[]

  isAnonymous Boolean @default(false)
  isVerified  Boolean @default(false) // Verified purchase

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([batchId, studentId])
}

// Teacher Reviews
model TeacherReview {
  id        String @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])
  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  rating     Int // 1-5
  comment    String?
  categories Json? // {clarity: 5, patience: 4, knowledge: 5}

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherId, studentId])
}

// ==================================================
// PAYMENT SYSTEM
// ==================================================

model Payment {
  id String @id @default(cuid())

  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  // Payment Details
  amount     Float
  paidAmount Float
  dueAmount  Float?
  tax        Float? @default(0)
  totalAmount Float?

  method PaymentMethod
  status PaymentStatus @default(PENDING)

  // Transaction
  transactionId   String? @unique
  paymentGateway  String? // SSLCommerz, Razorpay, Stripe, etc.
  gatewayResponse Json? // Store raw gateway response

  // Card Details (masked)
  cardLast4   String?
  cardBrand   String?
  upiId       String?
  bankName    String?

  // Manual Payment
  manualReference String? // Bank slip number, bKash TrxID
  verifiedBy      String? // Teacher/Moderator/Admin ID
  verifiedAt      DateTime?

  // Dates
  paymentDate DateTime  @default(now())
  dueDate     DateTime?

  // Receipt
  receiptUrl    String?
  invoiceNumber String? @unique

  // Reminders
  remindersSent    Int       @default(0)
  lastReminderSent DateTime?

  // Refund
  refundAmount   Float?
  refundReason   String?
  refundedAt     DateTime?
  refundId       String?

  notes    String?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([enrollmentId])
  @@index([status])
  @@index([dueDate])
}

// ==================================================
// LEARNING MATERIALS
// ==================================================

model Note {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String?

  // Content
  content  String? // Rich text
  fileUrl  String? // PDF, PPT, etc.
  fileType String? // pdf, video, slide
  fileSize Int? // in bytes
  duration Int? // for videos (seconds)
  pages    Int? // for PDFs

  // Relations
  teacherId String
  teacher   Teacher @relation("TeacherNotes", fields: [teacherId], references: [id])

  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id])

  subject String
  topic   String?
  topics  String[] // Multiple topics

  // Access
  isPublic   Boolean @default(false)
  isPremium  Boolean @default(false)
  price      Float? // if premium
  freePreview Boolean @default(false) // First few pages free

  // Stats
  downloads Int @default(0)
  views     Int @default(0)
  likes     Int @default(0)
  saves     Int @default(0)

  // Tags
  tags      String[]
  difficulty DifficultyLevel @default(INTERMEDIATE)

  // Downloads tracking
  downloadedBy Student[]
  savedBy      PostBookmark[]

  // SEO
  metaTitle       String?
  metaDescription String?
  metaKeywords    String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId])
  @@index([batchId])
  @@index([subject])
  @@index([isPublic])
}

// ==================================================
// QUIZ SYSTEM
// ==================================================

model Quiz {
  id          String  @id @default(cuid())
  title       String
  slug        String? @unique
  description String?

  teacherId String
  teacher   Teacher @relation("TeacherQuizzes", fields: [teacherId], references: [id])

  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id])

  // Quiz Settings
  timeLimit    Int? // in minutes
  totalMarks   Int
  passingMarks Int?
  negativeMarking Float @default(0)

  questions Question[]

  // Schedule
  startTime DateTime?
  endTime   DateTime?
  isActive  Boolean    @default(false)
  status    QuizStatus @default(DRAFT)

  // Results
  showResult      Boolean @default(true)
  showAnswer      Boolean @default(false)
  showExplanation Boolean @default(true)
  showLeaderboard Boolean @default(true)
  allowRetake     Boolean @default(false)
  maxAttempts     Int     @default(1)

  // Attempts
  attempts    QuizAttempt[]

  // Metadata
  difficulty DifficultyLevel @default(INTERMEDIATE)
  subject    String?
  topics     String[]

  // Stats
  totalAttempts    Int @default(0)
  averageScore     Float @default(0)
  highestScore     Float @default(0)
  passRate         Float @default(0)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  quizResults QuizResult[]

  @@index([teacherId])
  @@index([batchId])
  @@index([status])
}

model Question {
  id     String @id @default(cuid())
  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  text          String
  type          String // MCQ, TRUE_FALSE, SHORT_ANSWER, MATCHING
  options       Json? // For MCQ: ["Option A", "Option B", ...]
  correctAnswer Json // For MCQ: index or value
  explanation   String?

  marks         Int   @default(1)
  negativeMarks Float @default(0)

  // For matching questions
  matchPairs    Json? // {left: ["A", "B"], right: ["1", "2"], correct: {"A":"1", "B":"2"}}

  // Image/Media
  imageUrl      String?
  audioUrl      String?

  // Difficulty
  difficulty    DifficultyLevel @default(INTERMEDIATE)
  topic         String?

  order Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quizId])
}

model QuizAttempt {
  id String @id @default(cuid())

  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  // Attempt Details
  attemptNumber Int      @default(1)
  startTime     DateTime @default(now())
  endTime       DateTime?

  answers    Json? // Store student answers
  score      Int?
  percentage Float?
  isPassed   Boolean?

  // Detailed analysis
  questionWiseAnalysis Json? // Which questions correct/wrong
  timeSpent           Int? // Total seconds spent
  sectionWiseScore    Json? // Score per section

  // Auto-graded
  autoGraded Boolean @default(true)

  // Status
  isCompleted Boolean @default(false)

  // Feedback
  feedback    String?
  rating      Int? // Student rating of quiz

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  quizResult QuizResult?

  @@index([quizId])
  @@index([studentId])
  @@unique([quizId, studentId, attemptNumber])
}

model QuizResult {
  id String @id @default(cuid())

  attemptId String      @unique
  attempt   QuizAttempt @relation(fields: [attemptId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id])

  // Results
  totalMarks        Int
  obtainedMarks     Float
  percentage        Float
  rank              Int?
  totalParticipants Int

  // Analysis
  weakTopics   String[] // Topics where student scored low
  strongTopics String[] // Topics where student scored high
  timeAnalysis Json? // Time spent per question

  // Feedback
  feedback String?
  recommendations String[] // Suggested topics to review

  // Certificate
  certificateId String?
  certificate   Certificate?

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([quizId])
}

// ==================================================
// EXAM MANAGEMENT
// ==================================================

model Exam {
  id          String  @id @default(cuid())
  title       String
  slug        String? @unique
  description String?

  teacherId String
  teacher   Teacher @relation("TeacherExams", fields: [teacherId], references: [id])

  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id])

  // Exam Details
  type      String // Weekly, Monthly, Model Test, Final, Mock
  subject   String
  fullMarks Int
  passMarks Int?

  // Schedule
  examDate  DateTime
  startTime DateTime
  endTime   DateTime
  duration  Int // in minutes
  lateEntryAllowed Boolean @default(false)
  earlyExitAllowed Boolean @default(true)

  // Grading
  gradingType       String // AUTO, MANUAL, HYBRID
  isResultPublished Boolean @default(false)
  resultDate        DateTime?

  // Questions
  questionPaper String? // PDF URL
  answerSheet   String? // PDF URL
  instructions   String?

  // Results
  results ExamResult[]

  // Settings
  allowReview      Boolean @default(false)
  showRank         Boolean @default(true)
  showPercentile   Boolean @default(true)
  allowRecheck     Boolean @default(false)
  recheckFee       Float? @default(0)

  // Status
  status ExamStatus @default(DRAFT)

  // Stats
  totalStudents  Int @default(0)
  appearedCount  Int @default(0)
  passedCount    Int @default(0)
  averageMarks   Float @default(0)
  highestMarks   Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId])
  @@index([batchId])
  @@index([examDate])
}

model ExamResult {
  id String @id @default(cuid())

  examId String
  exam   Exam   @relation(fields: [examId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  // Marks
  obtainedMarks Float
  totalMarks    Int
  percentage    Float

  // Details
  grade    String?
  rank     Int?
  percentile Float?
  position String? // 1st, 2nd, 3rd, etc.

  // Subject-wise marks
  subjectWiseMarks Json? // {"physics": 75, "math": 80}
  topicWiseMarks   Json? // {"kinematics": 15, "optics": 20}

  // Answer Script
  answerScript String? // PDF URL
  answerScriptUrl String?
  reviewedBy    String?

  // Teacher Feedback
  feedback String?
  gradedBy String? // Teacher/Moderator ID
  gradedAt DateTime?
  remarks  String?

  // Recheck
  recheckRequested Boolean @default(false)
  recheckApproved  Boolean @default(false)
  recheckResult    Json?
  recheckFee       Float?
  recheckPaid      Boolean @default(false)

  // Guardian
  sentToGuardian Boolean   @default(false)
  guardianSentAt DateTime?

  // Certificate
  certificateId String?
  certificate   Certificate?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([examId, studentId])
  @@index([studentId])
  @@index([rank])
}

// ==================================================
// ATTENDANCE
// ==================================================

model Attendance {
  id String @id @default(cuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  batchId String
  batch   Batch  @relation(fields: [batchId], references: [id])

  date   DateTime         @default(now())
  status AttendanceStatus

  // Details
  checkInTime  DateTime?
  checkOutTime DateTime?
  duration     Int? // in minutes

  // For online classes
  ipAddress  String?
  deviceInfo String?
  location   String?
  connectionData Json? // Network info

  // Marked by
  markedBy String? // Teacher/Moderator ID
  verified Boolean @default(false)

  // Late reason
  lateReason  String?
  excusedBy   String?
  excusedAt   DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, batchId, date])
  @@index([batchId, date])
  @@index([studentId])
}

// ==================================================
// LIVE SESSIONS
// ==================================================

model LiveSession {
  id        String @id @default(cuid())
  title     String
  description String?

  teacherId String
  teacher   Teacher @relation("TeacherSessions", fields: [teacherId], references: [id])

  batchId   String
  batch     Batch   @relation(fields: [batchId], references: [id])

  // Schedule
  startTime DateTime
  endTime   DateTime
  duration  Int // in minutes

  // Meeting details
  meetingUrl    String?
  platform      String // Zoom, Google Meet, etc.
  meetingId     String?
  meetingPassword String?
  recordingUrl  String? // Post-session recording

  // Status
  isLive        Boolean @default(false)
  isCompleted   Boolean @default(false)
  isRecorded    Boolean @default(false)
  recordingAvailable Boolean @default(false)

  // Attendance
  attendees     LiveSessionAttendance[]
  attendanceCount Int @default(0)

  // Materials
  resources     Json? // Links, files shared during session

  // Feedback
  feedback      Json? // Session feedback from students

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId])
  @@index([startTime])
}

model LiveSessionAttendance {
  id           String @id @default(cuid())
  sessionId    String
  session      LiveSession @relation(fields: [sessionId], references: [id])
  studentId    String
  student      Student     @relation("StudentSessions", fields: [studentId], references: [id])

  joinedAt     DateTime?
  leftAt       DateTime?
  duration     Int? // seconds
  isPresent    Boolean @default(false)

  // Connection details
  ipAddress    String?
  deviceInfo   String?

  createdAt    DateTime @default(now())

  @@unique([sessionId, studentId])
}

// ==================================================
// ASSIGNMENTS
// ==================================================

model Assignment {
  id          String @id @default(cuid())
  title       String
  description String?

  teacherId String
  teacher   Teacher @relation("TeacherAssignments", fields: [teacherId], references: [id])

  batchId   String
  batch     Batch   @relation(fields: [batchId], references: [id])

  // Details
  type        String // HOMEWORK, PROJECT, PRACTICE
  totalMarks  Int
  passingMarks Int?
  weightage   Float? // Weightage in final grade

  // Files
  questionFile String? // PDF URL
  resources    Json? // Additional resources

  // Schedule
  issuedDate  DateTime @default(now())
  dueDate     DateTime
  lateSubmission Boolean @default(false)
  latePenalty    Float? // Percentage deduction

  // Status
  status      AssignmentStatus @default(DRAFT)
  isPublished Boolean @default(false)

  // Submissions
  submissions AssignmentSubmission[]

  // Stats
  totalSubmissions Int @default(0)
  gradedCount      Int @default(0)
  averageScore     Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId])
  @@index([dueDate])
}

model AssignmentSubmission {
  id           String @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id])

  // Submission
  submittedAt  DateTime
  content      String? // Text answer
  files        Json? // Submitted files URLs
  comments     String?

  // Status
  status       SubmissionStatus @default(SUBMITTED)
  isLate       Boolean @default(false)

  // Grading
  obtainedMarks Float?
  feedback      String?
  gradedBy      String? // Teacher ID
  gradedAt      DateTime?

  // Re-evaluation
  reevalRequested Boolean @default(false)
  reevalReason    String?
  reevalResult    Json?

  // Plagiarism
  plagiarismScore Float? @default(0)
  plagiarismReport String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assignmentId, studentId])
  @@index([studentId])
}

// ==================================================
// DOUBT SOLVING SYSTEM
// ==================================================

model Doubt {
  id          String @id @default(cuid())
  title       String
  description String?

  // Author
  studentId String
  student   Student @relation("StudentDoubts", fields: [studentId], references: [id])

  // Context
  batchId    String?
  batch      Batch?   @relation(fields: [batchId], references: [id])
  subject    String?
  topic      String?
  questionId String? // If related to specific question

  // Media
  images     String[]
  files      Json?

  // Status
  status     DoubtStatus @default(OPEN)
  priority   String? // LOW, MEDIUM, HIGH

  // Assignment
  assignedTo String? // Teacher ID
  assignedAt DateTime?

  // Resolution
  answers    DoubtAnswer[]
  resolvedAt DateTime?
  resolvedBy String?

  // Satisfaction
  satisfactionRating Int?
  feedback           String?

  // Stats
  viewCount  Int @default(0)
  upvoteCount Int @default(0)

  // Metadata
  tags       String[]
  isPrivate  Boolean @default(false) // Private between student and teacher

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([status])
  @@index([assignedTo])
}

model DoubtAnswer {
  id       String @id @default(cuid())
  doubtId  String
  doubt    Doubt  @relation(fields: [doubtId], references: [id])

  // Author (Teacher or Student)
  teacherId String?
  teacher   Teacher? @relation("TeacherDoubts", fields: [teacherId], references: [id])
  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])

  // Content
  content  String
  images   String[]
  files    Json?

  // Status
  isAccepted    Boolean @default(false)
  isOfficial    Boolean @default(false) // From official teacher

  // Interaction
  upvotes  Int @default(0)
  upvotedBy String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doubtId])
}

// ==================================================
// CERTIFICATES
// ==================================================

model Certificate {
  id          String @id @default(cuid())
  certificateNumber String @unique

  // Type
  type        CertificateType
  title       String
  description String?

  // Recipient
  studentId   String
  student     Student @relation("StudentCertificates", fields: [studentId], references: [id])

  // Issuer
  teacherId   String?
  teacher     Teacher? @relation("TeacherCertificates", fields: [teacherId], references: [id])
  batchId     String?
  batch       Batch?   @relation(fields: [batchId], references: [id])
  quizId      String?
  examId      String?

  // Details
  issueDate   DateTime @default(now())
  expiryDate  DateTime?
  grade       String?
  score       Float?
  duration    String? // Course duration

  // File
  pdfUrl      String?
  imageUrl    String?
  metadata    Json?

  // Verification
  isVerified  Boolean @default(true)
  verifiedBy  String?
  verifiedAt  DateTime?

  // Sharing
  shareableLink String? @unique
  viewCount     Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([certificateNumber])
}

// ==================================================
// NOTIFICATION SYSTEM
// ==================================================

model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  channel NotificationChannel @default(INAPP)

  title   String
  message String
  data    Json? // Additional data

  // Status
  isRead Boolean   @default(false)
  readAt DateTime?

  // Delivery
  isDelivered   Boolean   @default(false)
  deliveredAt   DateTime?
  deliveryError String?
  retryCount    Int       @default(0)

  // Schedule
  scheduledFor DateTime?
  sentAt       DateTime?

  // Action
  actionUrl   String?
  actionLabel String?

  // Image
  imageUrl    String?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

model NotificationPreference {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Preferences per channel
  emailEnabled    Boolean @default(true)
  smsEnabled      Boolean @default(true)
  whatsappEnabled Boolean @default(false)
  inappEnabled    Boolean @default(true)
  pushEnabled     Boolean @default(true)

  // Quiet hours
  quietHoursStart Int? // Hour (0-23)
  quietHoursEnd   Int?

  // Preferences per type
  preferences Json // {"PAYMENT_REMINDER": true, "EXAM_UPDATE": false}

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId])
}

// ==================================================
// MEDIA/POST SYSTEM
// ==================================================

// Main Post Model
model Post {
  id             String         @id @default(cuid())
  title          String?
  content        String?        // Rich text content
  slug           String?        @unique
  excerpt        String?        // Short description for preview

  // Media Type
  type           MediaType      @default(TEXT)
  status         PostStatus     @default(DRAFT)
  visibility     PostVisibility @default(PUBLIC)

  // Author (can be Teacher or Student)
  teacherId      String?
  teacher        Teacher?       @relation("TeacherPosts", fields: [teacherId], references: [id])
  
  studentId      String?
  student        Student?       @relation("StudentPosts", fields: [studentId], references: [id])

  // If post is related to specific batch/course
  batchId        String?
  batch          Batch?         @relation(fields: [batchId], references: [id])
  
  courseId       String?
  course         Course?        @relation(fields: [courseId], references: [id])

  // Media Attachments
  media          MediaAttachment[]

  // Links
  linkUrl        String?        // For LINK type posts
  linkTitle      String?
  linkDescription String?
  linkImage      String?

  // Polls (optional)
  poll           Poll?

  // Statistics
  views          Int            @default(0)
  uniqueViews    Int            @default(0)
  shares         Int            @default(0)
  saves          Int            @default(0)
  
  // Engagement
  reactions      PostReaction[]
  comments       Comment[]
  bookmarks      PostBookmark[]

  // Tags
  tags           String[]
  topics         String[]       // Physics topics covered

  // Featured
  isFeatured     Boolean        @default(false)
  isPinned       Boolean        @default(false)
  pinnedUntil    DateTime?
  pinnedBy       String?

  // SEO
  metaTitle      String?
  metaDescription String?
  metaKeywords   String[]

  // Schedule
  publishedAt    DateTime?
  scheduledFor   DateTime?

  // Moderation
  reportedBy     String[]       // User IDs who reported
  reportCount    Int            @default(0)
  hiddenReason   String?
  hiddenBy       String?        // Moderator ID
  hiddenAt       DateTime?

  // Timestamps
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([teacherId])
  @@index([studentId])
  @@index([batchId])
  @@index([status])
  @@index([createdAt])
  @@index([isFeatured])
  @@index([isPinned])
}

// Media Attachments
model MediaAttachment {
  id             String         @id @default(cuid())
  postId         String
  post           Post           @relation(fields: [postId], references: [id], onDelete: Cascade)

  // File details
  url            String
  type           String         // "image/jpeg", "video/mp4", etc.
  category       MediaType      @default(IMAGE)
  
  // Metadata
  filename       String
  fileSize       Int            // in bytes
  duration       Int?           // for videos (seconds)
  width          Int?           // for images
  height         Int?           // for images
  thumbnail      String?        // for videos
  
  // Caption
  caption        String?
  altText        String?        // for accessibility
  
  // Order
  displayOrder   Int            @default(0)

  createdAt      DateTime       @default(now())

  @@index([postId])
}

// Post Reactions (Likes, etc.)
model PostReaction {
  id             String         @id @default(cuid())
  postId         String
  post           Post           @relation(fields: [postId], references: [id], onDelete: Cascade)

  // User who reacted
  teacherId      String?
  teacher        Teacher?       @relation(fields: [teacherId], references: [id])
  
  studentId      String?
  student        Student?       @relation("StudentReactions", fields: [studentId], references: [id])

  guardianId     String?
  guardian       Guardian?      @relation(fields: [guardianId], references: [id])

  type           ReactionType   @default(LIKE)

  createdAt      DateTime       @default(now())

  @@unique([postId, studentId, teacherId, guardianId])
  @@index([postId])
  @@index([type])
}

// Comments
model Comment {
  id             String         @id @default(cuid())
  content        String         // Comment text
  postId         String
  post           Post           @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Parent comment for replies
  parentId       String?
  parent         Comment?       @relation("CommentReplies", fields: [parentId], references: [id])
  replies        Comment[]      @relation("CommentReplies")

  // Author
  teacherId      String?
  teacher        Teacher?       @relation(fields: [teacherId], references: [id])
  
  studentId      String?
  student        Student?       @relation("StudentComments", fields: [studentId], references: [id])

  guardianId     String?
  guardian       Guardian?      @relation(fields: [guardianId], references: [id])

  // Media in comment
  mediaUrl       String?
  mediaType      String?

  // Stats
  likes          Int            @default(0)
  reactionCount  Int            @default(0)
  
  // Reactions on comments
  reactions      CommentReaction[]

  // Status
  status         CommentStatus  @default(ACTIVE)
  isEdited       Boolean        @default(false)
  editHistory    Json?          // Store previous versions

  // Moderation
  reportedBy     String[]       // User IDs who reported
  reportCount    Int            @default(0)
  hiddenReason   String?
  hiddenBy       String?        // Moderator ID
  hiddenAt       DateTime?

  // Metadata
  ipAddress      String?
  userAgent      String?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([postId])
  @@index([parentId])
  @@index([studentId])
  @@index([teacherId])
  @@index([createdAt])
}

// Comment Reactions
model CommentReaction {
  id             String         @id @default(cuid())
  commentId      String
  comment        Comment        @relation(fields: [commentId], references: [id], onDelete: Cascade)

  // User who reacted
  teacherId      String?
  teacher        Teacher?       @relation(fields: [teacherId], references: [id])
  
  studentId      String?
  student        Student?       @relation(fields: [studentId], references: [id])

  guardianId     String?
  guardian       Guardian?      @relation(fields: [guardianId], references: [id])

  type           ReactionType   @default(LIKE)

  createdAt      DateTime       @default(now())

  @@unique([commentId, studentId, teacherId, guardianId])
}

// Post Bookmarks/Saves
model PostBookmark {
  id             String         @id @default(cuid())
  postId         String
  post           Post           @relation(fields: [postId], references: [id], onDelete: Cascade)

  // User who bookmarked
  studentId      String?
  student        Student?       @relation(fields: [studentId], references: [id])
  
  teacherId      String?
  teacher        Teacher?       @relation(fields: [teacherId], references: [id])

  guardianId     String?
  guardian       Guardian?      @relation(fields: [guardianId], references: [id])

  // Folders/Collections
  collectionId   String?
  collection     PostCollection? @relation(fields: [collectionId], references: [id])
  
  notes          String?        // Personal notes on this post

  createdAt      DateTime       @default(now())

  @@unique([postId, studentId, teacherId, guardianId])
  @@index([collectionId])
}

// Polls in Posts
model Poll {
  id             String         @id @default(cuid())
  postId         String         @unique
  post           Post           @relation(fields: [postId], references: [id], onDelete: Cascade)

  question       String
  options        Json           // [{id: "1", text: "Option A", votes: 0}]
  multipleChoice Boolean        @default(false)
  
  // Settings
  expiresAt      DateTime?
  isAnonymous    Boolean        @default(false)
  showResults    Boolean        @default(true)
  allowNewOptions Boolean       @default(false)

  // Statistics
  totalVotes     Int            @default(0)

  // Votes
  votes          PollVote[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

// Poll Votes
model PollVote {
  id             String         @id @default(cuid())
  pollId         String
  poll           Poll           @relation(fields: [pollId], references: [id], onDelete: Cascade)

  // Voter
  studentId      String?
  student        Student?       @relation(fields: [studentId], references: [id])
  
  teacherId      String?
  teacher        Teacher?       @relation(fields: [teacherId], references: [id])

  guardianId     String?
  guardian       Guardian?      @relation(fields: [guardianId], references: [id])

  // Selected options (array for multiple choice)
  selectedOptions String[]      // ["1", "3"]

  // IP for anonymous tracking
  ipAddress      String?

  createdAt      DateTime       @default(now())

  @@unique([pollId, studentId, teacherId, guardianId])
}

// Post Collections/Folders
model PostCollection {
  id             String         @id @default(cuid())
  name           String
  description    String?
  slug           String         @unique

  // Owner
  studentId      String?
  student        Student?       @relation(fields: [studentId], references: [id])
  
  teacherId      String?
  teacher        Teacher?       @relation(fields: [teacherId], references: [id])

  guardianId     String?
  guardian       Guardian?      @relation(fields: [guardianId], references: [id])

  // Collection items
  bookmarks      PostBookmark[]

  // Privacy
  isPublic       Boolean        @default(false)
  shareableLink  String?        @unique

  // Cover image
  coverImage     String?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([studentId])
}

// Post Views Tracking
model PostView {
  id             String         @id @default(cuid())
  postId         String
  post           Post           @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Viewer
  studentId      String?
  student        Student?       @relation(fields: [studentId], references: [id])
  
  teacherId      String?
  teacher        Teacher?       @relation(fields: [teacherId], references: [id])

  guardianId     String?
  guardian       Guardian?      @relation(fields: [guardianId], references: [id])

  // Anonymous view tracking
  sessionId      String?        // For non-logged in users
  ipAddress      String?
  
  // View duration
  viewedAt       DateTime       @default(now())
  duration       Int?           // seconds spent viewing

  @@index([postId])
  @@index([viewedAt])
}

// Post Shares
model PostShare {
  id             String         @id @default(cuid())
  postId         String
  post           Post           @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Sharer
  studentId      String?
  student        Student?       @relation(fields: [studentId], references: [id])
  
  teacherId      String?
  teacher        Teacher?       @relation(fields: [teacherId], references: [id])

  guardianId     String?
  guardian       Guardian?      @relation(fields: [guardianId], references: [id])

  // Share details
  platform       String?        // "facebook", "whatsapp", "copy_link", etc.
  sharedTo       String?        // specific group/individual

  createdAt      DateTime       @default(now())
}

// ==================================================
// BLOG SYSTEM
// ==================================================

model Blog {
  id      String  @id @default(cuid())
  title   String
  slug    String  @unique
  excerpt String?
  content String // Rich text

  teacherId String
  teacher   Teacher @relation("TeacherBlogs", fields: [teacherId], references: [id])

  // Media
  featuredImage String?
  thumbnail     String?
  gallery       String[]

  // SEO
  metaTitle       String?
  metaDescription String?
  metaKeywords    String[]

  // Stats
  views  Int @default(0)
  likes  Int @default(0)
  shares Int @default(0)
  readTime Int? // in minutes

  // Status
  isPublished Boolean   @default(false)
  publishedAt DateTime?

  // Categories
  categories String[] // ["HSC Tips", "Exam Strategy", etc.]
  tags       String[]

  // Comments
  allowComments Boolean @default(true)
  comments      BlogComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId])
  @@index([publishedAt])
}

model BlogComment {
  id        String @id @default(cuid())
  blogId    String
  blog      Blog   @relation(fields: [blogId], references: [id])

  name      String?
  email     String?
  content   String

  status    String @default("PENDING") // PENDING, APPROVED, SPAM
  isApproved Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([blogId])
}

// ==================================================
// IMPORTANT NOTICES
// ==================================================

model Announcement {
  id      String @id @default(cuid())
  title   String
  content String

  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id])

  // Target
  targetRole UserRole? // If null, send to all batch members

  // Priority
  isUrgent Boolean @default(false)
  isPinned Boolean @default(false)

  // Expiry
  expiresAt DateTime?

  // Stats
  views Int @default(0)

  // Attachments
  attachments Json?

  createdBy String // Teacher/Moderator ID
  creator   Teacher? @relation("TeacherAnnouncements", fields: [createdBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId])
  @@index([createdAt])
}

// ==================================================
// ANALYTICS & TRACKING
// ==================================================

model StudentProgress {
  id String @id @default(cuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  batchId String
  batch   Batch  @relation(fields: [batchId], references: [id])

  // Performance metrics
  avgQuizScore Float?
  avgExamScore Float?
  attendance   Float? // Percentage
  assignmentsCompleted Int @default(0)
  totalAssignments Int @default(0)

  // Weak areas
  weakSubjects String[]
  weakTopics   String[]
  strongTopics String[]

  // Improvement
  improvementRate Float? // Percentage improvement over time
  scoreHistory    Json? // Historical scores

  // Last activity
  lastActive DateTime?
  totalStudyTime Int? // Total minutes studied

  // Predictions
  predictedScore Int?
  confidenceScore   Float? // 0-1
  recommendedTopics String[]

  // Engagement
  loginCount    Int @default(0)
  resourceViews Int @default(0)
  doubtCount    Int @default(0)

  // Metadata
  metadata Json?

  updatedAt DateTime @updatedAt

  @@unique([studentId, batchId])
  @@index([studentId])
}

// User Activity Tracking
model UserActivity {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id])

  action    String // LOGIN, VIEW_BATCH, TAKE_QUIZ, etc.
  entity    String? // Batch, Quiz, Exam, etc.
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  duration  Int? // seconds spent

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// Device Tokens for Push Notifications
model DeviceToken {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id])

  token     String @unique
  platform  String // ios, android, web
  deviceId  String?
  isActive  Boolean @default(true)

  lastUsed  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ==================================================
// SUPPORT SYSTEM
// ==================================================

model SupportTicket {
  id          String @id @default(cuid())
  ticketNumber String @unique

  userId      String
  user        User   @relation("UserTickets", fields: [userId], references: [id])

  // Ticket details
  subject     String
  description String
  category    String // TECHNICAL, PAYMENT, ACCOUNT, COURSE, OTHER
  priority    SupportTicketPriority @default(MEDIUM)
  status      SupportTicketStatus @default(OPEN)

  // Attachments
  attachments Json?

  // Assignment
  assignedTo  String?
  assignedToUser User? @relation("AssignedTickets", fields: [assignedTo], references: [id])
  assignedAt  DateTime?

  // Conversation
  messages    TicketMessage[]

  // Resolution
  resolvedAt  DateTime?
  resolvedBy  String?
  resolution  String?
  satisfactionRating Int? // 1-5

  // Metadata
  source      String? // WEBSITE, APP, EMAIL, PHONE
  tags        String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([assignedTo])
}

model TicketMessage {
  id         String @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id])

  senderId   String
  sender     User   @relation(fields: [senderId], references: [id])

  message    String
  attachments Json?
  isInternal Boolean @default(false) // Internal notes

  createdAt DateTime @default(now())

  @@index([ticketId])
}

// ==================================================
// SYSTEM & SECURITY
// ==================================================

model Session {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token        String  @unique
  refreshToken String? @unique

  ipAddress String?
  device    String?
  browser   String?
  os        String?
  location  String?

  isActive   Boolean   @default(true)
  expiresAt  DateTime
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([token])
}

model AuditLog {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action   String
  entity   String // "User", "Batch", "Payment", etc.
  entityId String?

  changes  Json? // Before/after values
  metadata Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model OTP {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  email String?
  phone String?

  code    String
  purpose String // LOGIN, VERIFY, RESET_PASSWORD, PAYMENT

  isUsed    Boolean  @default(false)
  expiresAt DateTime
  attempts  Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([userId])
}

// ==================================================
// COUPONS & OFFERS
// ==================================================

model Coupon {
  id          String  @id @default(cuid())
  code        String  @unique
  description String?

  // Discount
  discountType  String // PERCENTAGE, FIXED
  discountValue Float

  // Validity
  validFrom  DateTime
  validUntil DateTime
  maxUses    Int?
  usedCount  Int      @default(0)

  // Restrictions
  minPurchase       Float?
  maxDiscount       Float?
  applicableBatches String[] // Batch IDs
  applicableCourses String[] // Course IDs
  applicablePlans   String[] // Subscription plan IDs

  // Per user
  perUserLimit Int @default(1)
  firstTimeOnly Boolean @default(false)

  // Status
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([validFrom, validUntil])
}

// ==================================================
// SUBSCRIPTION PLANS
// ==================================================

model SubscriptionPlan {
  id           String @id @default(cuid())
  name         String
  description  String?
  price        Float
  durationDays Int
  billingCycle String // MONTHLY, QUARTERLY, YEARLY

  maxStudents Int?
  maxBatches  Int?
  maxCourses  Int?
  storage     Int? // in GB

  features    Json // Feature list with limits

  isPopular   Boolean @default(false)
  isActive    Boolean @default(true)

  createdAt            DateTime              @default(now())
  teacherSubscriptions TeacherSubscription[]
}

model TeacherSubscription {
  id String @id @default(cuid())

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  planId String
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  startDate DateTime
  endDate   DateTime
  nextBillingDate DateTime?

  isActive   Boolean @default(true)
  autoRenew  Boolean @default(true)

  paymentId     String?
  paymentStatus PaymentStatus @default(PENDING)
  amountPaid    Float?
  invoiceUrl    String?

  usageStats    Json? // Current usage against limits

  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId])
  @@index([endDate])
}

// ==================================================
// LEAD MANAGEMENT
// ==================================================

model Lead {
  id    String  @id @default(cuid())
  name  String?
  phone String?
  email String?

  source   String? // Facebook, Website, WhatsApp, Referral
  medium   String? // ad, organic, campaign
  campaign String?
  interest String? // Subject or batch

  // Status
  status     String @default("NEW") // NEW, CONTACTED, QUALIFIED, CONVERTED, LOST
  converted  Boolean @default(false)
  convertedAt DateTime?

  // Follow up
  assignedTo    String? // Sales person ID
  lastContacted DateTime?
  nextFollowUp  DateTime?
  notes         String?

  // Lead score
  score Int @default(0)

  // Form data
  formData Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([email])
  @@index([status])
}

// ==================================================
// REFERRAL SYSTEM
// ==================================================

model Referral {
  id String @id @default(cuid())

  referrerId String
  referrer   User   @relation("Referrer", fields: [referrerId], references: [id])

  referredId String?
  referred   User?   @relation("Referred", fields: [referredId], references: [id])

  // Referral details
  code        String @unique
  reward      Float?
  rewardType  String // DISCOUNT, CASH, COURSE
  status      String // PENDING, COMPLETED, PAID, EXPIRED

  // Conversion
  convertedAt DateTime?
  conversionValue Float?

  // Payment
  paidAt      DateTime?
  paymentId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([referrerId])
  @@index([code])
}

// ==================================================
// SYSTEM CONFIGURATION
// ==================================================

model SystemConfig {
  id        String @id @default(cuid())
  key       String @unique
  value     Json
  category  String
  description String?

  isPublic  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================================================
// IMPORTANT INDEXES FOR PERFORMANCE
// ==================================================

